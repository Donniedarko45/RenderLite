# ------------ Domain / TLS ------------
BASE_DOMAIN=example.com
APP_HOST=app.example.com
API_HOST=api.example.com
TRAEFIK_DASHBOARD_HOST=traefik.example.com
ACME_EMAIL=devops@example.com

# Generate with:
# docker run --rm httpd:2.4-alpine htpasswd -nbB admin 'strong-password'
# IMPORTANT: replace each $ with $$ before saving in this file.
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$replace_with_bcrypt_hash

# ------------ Core secrets ------------
JWT_SECRET=replace-with-a-long-random-secret
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ------------ GitHub OAuth ------------
GITHUB_CLIENT_ID=replace-me
GITHUB_CLIENT_SECRET=replace-me

# ------------ Database / Redis ------------
POSTGRES_USER=renderlite
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=renderlite
DATABASE_URL=postgresql://renderlite:replace-with-strong-password@postgres:5432/renderlite?schema=public
REDIS_URL=redis://redis:6379

# ------------ Optional dev bypass (keep false in production) ------------
DEV_AUTH_ENABLED=false
DEV_AUTH_EMAIL=dev@renderlite.local
DEV_AUTH_USERNAME=dev-user
VITE_DEV_AUTH_ENABLED=false
